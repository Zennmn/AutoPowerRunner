<Window x:Class="AutoPowerRunner.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoPowerRunner"
        Title="编辑任务"
        Icon="{StaticResource AppShieldLogoImage}"
        Width="720"
        Height="600"
        MinWidth="640"
        MinHeight="540"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FB"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <local:ChineseDisplayConverter x:Key="ChineseDisplay" />

        <SolidColorBrush x:Key="Brand" Color="#2563EB" />
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#172033" />
        <SolidColorBrush x:Key="TextSecondary" Color="#667085" />
        <SolidColorBrush x:Key="Border" Color="#E4E9F0" />
        <SolidColorBrush x:Key="FieldBorder" Color="#D7DEE8" />

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource Brand}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="FieldChrome"
                                Padding="10,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FieldChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldChrome" Property="BorderBrush" Value="#B9C7DA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FieldChrome" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadOnlyField" TargetType="Border">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#F5F7FA" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="ReadOnlyFieldText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckChrome"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFF"
                                    BorderBrush="#B9C7DA"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Path x:Name="CheckMark"
                                      Width="10"
                                      Height="7"
                                      Data="M0,3.5 L3.5,7 L10,0"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource Brand}" />
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#B9C7DA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource Brand}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brand}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E56D8" />
                    <Setter Property="BorderBrush" Value="#1E56D8" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FB">
        <Border Margin="20"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,14,24,12">
                    <TextBlock Text="编辑任务"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Margin="0,3,0,0"
                               Text="配置任务路径、运行方式和启用状态"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}" />
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource Border}" />

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="任务名称" />
                        <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource ModernTextBox}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="任务类型" />
                        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource ReadOnlyField}">
                            <TextBlock x:Name="TypeValue" Style="{StaticResource ReadOnlyFieldText}" />
                        </Border>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="文件路径" />
                        <TextBox x:Name="PathBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,10" Style="{StaticResource ModernTextBox}" />
                        <Button Grid.Row="2" Grid.Column="2" MinWidth="82" Margin="0,0,0,10" Style="{StaticResource BaseButton}" Click="Browse_Click" Content="浏览" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="启动参数" />
                        <TextBox x:Name="ArgumentsBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource ModernTextBox}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="工作目录" />
                        <TextBox x:Name="WorkingDirectoryBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource ModernTextBox}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,16,10" Style="{StaticResource FieldLabel}" Text="运行模式" />
                        <Border Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Style="{StaticResource ReadOnlyField}">
                            <TextBlock x:Name="RunModeValue" Style="{StaticResource ReadOnlyFieldText}" />
                        </Border>

                        <CheckBox x:Name="EnabledBox"
                                  Grid.Row="6"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,1,0,2"
                                  Style="{StaticResource ModernCheckBox}"
                                  Content="启用此任务" />
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Padding="24,11"
                        Background="#FAFBFC"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,12,12">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button MinWidth="82" Margin="0,0,8,0" Style="{StaticResource BaseButton}" IsCancel="True" Content="取消" />
                        <Button MinWidth="90" Style="{StaticResource PrimaryButton}" Click="Save_Click" Content="保存更改" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
