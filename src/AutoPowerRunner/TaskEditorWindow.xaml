<Window x:Class="AutoPowerRunner.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoPowerRunner"
        Title="任务"
        Width="640"
        Height="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <local:ChineseDisplayConverter x:Key="ChineseDisplay" />

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#C9D5E1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="#C9D5E1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C9D5E1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1677FF" />
            <Setter Property="BorderBrush" Value="#1677FF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Padding="18"
            Background="#FFFFFF"
            BorderBrush="#D9E3EE"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="116" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="任务名称" />
            <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="任务类型" />
            <ComboBox x:Name="TypeBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ChineseDisplay}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="文件路径" />
            <TextBox x:Name="PathBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,12" />
            <Button Grid.Row="2" Grid.Column="2" MinWidth="82" Margin="0,0,0,12" Click="Browse_Click" Content="浏览" />

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="启动参数" />
            <TextBox x:Name="ArgumentsBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="工作目录" />
            <TextBox x:Name="WorkingDirectoryBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="运行模式" />
            <ComboBox x:Name="RunModeBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource ChineseDisplay}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <CheckBox x:Name="EnabledBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,12" Content="启用此任务" />

            <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="82" Margin="0,0,8,0" IsCancel="True" Content="取消" />
                <Button MinWidth="82" Style="{StaticResource PrimaryButton}" Click="Save_Click" Content="保存" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
