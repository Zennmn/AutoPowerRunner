<Window x:Class="AutoPowerRunner.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoPowerRunner"
        mc:Ignorable="d"
        Title="管理员自启动器"
        Icon="{StaticResource AppShieldLogoImage}"
        Width="1320"
        Height="820"
        MinWidth="900"
        MinHeight="620"
        Background="#F5F7FB"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SizeChanged="MainWindow_SizeChanged">
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <local:ChineseDisplayConverter x:Key="ChineseDisplay" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <SolidColorBrush x:Key="Brand" Color="#2563EB" />
        <SolidColorBrush x:Key="BrandSoft" Color="#EAF1FF" />
        <SolidColorBrush x:Key="Canvas" Color="#F5F7FB" />
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#172033" />
        <SolidColorBrush x:Key="TextSecondary" Color="#667085" />
        <SolidColorBrush x:Key="Border" Color="#E4E9F0" />
        <SolidColorBrush x:Key="Success" Color="#16A05D" />
        <SolidColorBrush x:Key="Danger" Color="#D92D20" />
        <SolidColorBrush x:Key="Warning" Color="#F79009" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="InnerCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B9C7DA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource Brand}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brand}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E56D8" />
                    <Setter Property="BorderBrush" Value="#1E56D8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Foreground" Value="{StaticResource Danger}" />
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brand}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayContextMenu" TargetType="ContextMenu">
            <Setter Property="MinWidth" Value="176" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Margin="4"
                                Padding="6"
                                Background="#FAFAFA"
                                BorderBrush="#D8D8D8"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Opacity="0.18"
                                                  Color="#000000" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayMenuItem" TargetType="MenuItem">
            <Setter Property="Height" Value="27" />
            <Setter Property="Padding" Value="28,0,18,0" />
            <Setter Property="Foreground" Value="#0F0F0F" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Margin="1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#EEEEEE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayMenuSeparator" TargetType="Separator">
            <Setter Property="Height" Value="6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Grid Background="Transparent">
                            <Border Height="1"
                                    Margin="10,0"
                                    VerticalAlignment="Center"
                                    Background="#DADADA" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetaLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetaValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TaskListItem" TargetType="ListBoxItem">
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TaskItem_PreviewMouseRightButtonDown" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionBorder"
                                Padding="12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#F7F9FC" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#EAF1FF" />
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#BFD2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusChip" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#F1F3F6" />
            <Setter Property="BorderBrush" Value="#DDE2EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="TextElement.Foreground" Value="#7B8493" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LastResult.Status}" Value="Running">
                    <Setter Property="Background" Value="#DCEBFF" />
                    <Setter Property="BorderBrush" Value="#8DBBF2" />
                    <Setter Property="TextElement.Foreground" Value="#0B6BCB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastResult.Status}" Value="Restarting">
                    <Setter Property="Background" Value="#FFF4E5" />
                    <Setter Property="TextElement.Foreground" Value="#B56700" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastResult.Status}" Value="Succeeded">
                    <Setter Property="Background" Value="#EAF8F0" />
                    <Setter Property="TextElement.Foreground" Value="#16803C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastResult.Status}" Value="Failed">
                    <Setter Property="Background" Value="#FFF0EE" />
                    <Setter Property="TextElement.Foreground" Value="#C62A1E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LastResult.Status}" Value="FailedToStart">
                    <Setter Property="Background" Value="#FFF0EE" />
                    <Setter Property="TextElement.Foreground" Value="#C62A1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Canvas}">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1">
            <Grid x:Name="HeaderGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="34" Height="40" Source="{StaticResource AppShieldLogoImage}" Stretch="Uniform" />
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="管理员自启"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="任务控制台"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <WrapPanel x:Name="HeaderStatusPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Height="34" Padding="12,0" Background="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{Binding CurrentPermissionForeground}" />
                            <TextBlock Margin="7,0,0,0" Text="{Binding CurrentPermissionText}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Height="34" Margin="10,0,0,0" Padding="12,0" Background="{Binding AutostartStatusBackground}" BorderBrush="#CBE8D6" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="{Binding AutostartStatusForeground}" />
                            <TextBlock Margin="7,0,0,0" Text="{Binding AutostartStatusText}" Foreground="{Binding AutostartStatusForeground}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Margin="10,0,0,0"
                            Style="{StaticResource BaseButton}"
                            Command="{Binding ToggleAutostartCommand}"
                            Content="{Binding CompactToggleAutostartText}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TaskListColumn" Width="430" />
                <ColumnDefinition x:Name="WorkspaceGapColumn" Width="18" />
                <ColumnDefinition x:Name="TaskDetailColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="18,0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="启动任务" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Margin="9,2,0,0" Text="{Binding TaskCount}" Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="112"
                                    Height="36"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AddTask_Click">
                                <Button.ContextMenu>
                                    <ContextMenu Placement="Bottom" Style="{StaticResource TrayContextMenu}">
                                        <MenuItem Header="添加 PowerShell 脚本" Style="{StaticResource TrayMenuItem}" Click="ImportPowerShellScript_Click" />
                                        <MenuItem Header="添加 EXE 程序" Style="{StaticResource TrayMenuItem}" Click="ImportExecutable_Click" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Margin="5,0,0,0" Text="添加任务" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Tasks}"
                                 SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource TaskListItem}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ToolTip="右键可编辑或删除任务">
                            <ListBox.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Style="{StaticResource TrayContextMenu}">
                                    <MenuItem Header="编辑任务" Style="{StaticResource TrayMenuItem}" Click="EditTask_Click" />
                                    <Separator Style="{StaticResource TrayMenuSeparator}" />
                                    <MenuItem Header="删除任务" Style="{StaticResource TrayMenuItem}" Command="{Binding DeleteSelectedCommand}" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34" Height="34" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{StaticResource Brand}" CornerRadius="7">
                                            <Viewbox Margin="8" Stretch="Uniform">
                                                <Canvas Width="16" Height="16">
                                                    <Path x:Name="TaskIconPath"
                                                          Data="M4,2 L10,2 L13,5 L13,14 L4,14 Z M10,2 L10,5 L13,5"
                                                          Stroke="#FFFFFF"
                                                          StrokeThickness="1.6"
                                                          StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="8,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,3,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Type, Converter={StaticResource ChineseDisplay}, Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding RunMode, Converter={StaticResource ChineseDisplay}, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="2" Margin="0,0,6,0" Style="{StaticResource StatusChip}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LastResult, Converter={StaticResource ChineseDisplay}}" FontSize="11" FontWeight="SemiBold" />
                                        </Border>

                                        <Button Grid.Column="3"
                                                Width="38"
                                                Height="28"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.ToggleTaskEnabledCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="启用或停用任务">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Width="34" Height="20">
                                                        <Border x:Name="ToggleTrack" Background="#CDD5DF" CornerRadius="10" />
                                                        <Ellipse x:Name="ToggleThumb" Width="16" Height="16" Margin="2" HorizontalAlignment="Left" Fill="#FFFFFF" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter TargetName="ToggleTrack" Property="Background" Value="{StaticResource Brand}" />
                                                            <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ToggleTrack" Property="Opacity" Value="0.85" />
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="ToggleTrack" Property="Opacity" Value="0.45" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="PowerShellScript">
                                            <Setter TargetName="TaskIconPath" Property="Data" Value="M3,4 L13,4 L13,12 L3,12 Z M5,7 L7,8 L5,9 M8,10 L11,10" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="还没有启动任务" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                            <TextBlock Margin="0,6,0,0" Text="使用右上角的添加任务开始配置" Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="90" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="22,0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SelectedTask.Name, TargetNullValue=选择一个任务}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <Border Margin="10,0,0,0" Padding="8,4" Background="#E7F2FF" CornerRadius="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedTask.LastResult, Converter={StaticResource ChineseDisplay}}" Foreground="#1473D4" FontSize="11" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Margin="0,5,0,0" Foreground="{StaticResource TextSecondary}">
                                    <Run Text="{Binding SelectedTask.Type, Converter={StaticResource ChineseDisplay}, Mode=OneWay}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding SelectedTask.RunMode, Converter={StaticResource ChineseDisplay}, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Margin="0,0,8,0"
                                        Style="{StaticResource BaseButton}"
                                        Command="{Binding RunSelectedCommand}"
                                        Content="立即运行"
                                        Visibility="{Binding ShowRunSelectedAction, Converter={StaticResource BooleanToVisibility}}" />
                                <Button Margin="0,0,8,0"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding StopSelectedCommand}"
                                        Content="停止任务"
                                        Visibility="{Binding ShowStopSelectedAction, Converter={StaticResource BooleanToVisibility}}" />
                                <Button Style="{StaticResource PrimaryButton}" Click="EditTask_Click" IsEnabled="{Binding HasSelectedTask}" Content="编辑任务" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="DetailBodyGrid" Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="DetailPrimaryColumn" Width="1.65*" />
                            <ColumnDefinition x:Name="DetailGapColumn" Width="16" />
                            <ColumnDefinition x:Name="DetailSecondaryColumn" Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="DetailPrimaryPanel" Grid.Column="0">
                            <Border Style="{StaticResource InnerCard}" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="50" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="126" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionTitle}" Text="任务配置" />
                                    <TextBlock Grid.Row="2" Style="{StaticResource MetaLabel}" Text="文件路径" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.Path}" ToolTip="{Binding SelectedTask.Path}" />
                                    <TextBlock Grid.Row="3" Style="{StaticResource MetaLabel}" Text="启动参数" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.Arguments, TargetNullValue=无}" />
                                    <TextBlock Grid.Row="4" Style="{StaticResource MetaLabel}" Text="工作目录" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.WorkingDirectory}" ToolTip="{Binding SelectedTask.WorkingDirectory}" />
                                    <TextBlock Grid.Row="5" Style="{StaticResource MetaLabel}" Text="启用状态" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="未启用">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MetaValue}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTask.IsEnabled}" Value="True">
                                                        <Setter Property="Text" Value="已启用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Border Grid.Row="6" Grid.ColumnSpan="2" Margin="0,8,0,0" Padding="12,0" Background="#F5F7FA" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                                        <TextBlock Text="{Binding SelectedTask.Path}" FontFamily="Cascadia Mono,Consolas" FontSize="11" Foreground="#465267" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Margin="0,16,0,0" Style="{StaticResource InnerCard}" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                        <RowDefinition Height="28" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="126" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionTitle}" Text="最近运行" />
                                    <TextBlock Grid.Row="2" Style="{StaticResource MetaLabel}" Text="最后启动" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.LastResult.StartedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=—}" />
                                    <TextBlock Grid.Row="3" Style="{StaticResource MetaLabel}" Text="最后结束" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.LastResult.ExitedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=—}" />
                                    <TextBlock Grid.Row="4" Style="{StaticResource MetaLabel}" Text="退出码" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.LastResult.ExitCode, TargetNullValue=—}" />
                                    <TextBlock Grid.Row="5" Style="{StaticResource MetaLabel}" Text="重启次数" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetaValue}" Text="{Binding SelectedTask.LastResult.RestartCount}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="DetailSecondaryPanel" Grid.Column="2">
                            <Border Style="{StaticResource InnerCard}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="当前状态" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding SelectedTask.LastResult, Converter={StaticResource ChineseDisplay}}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding SelectedTask.LastResult.Summary}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0" Style="{StaticResource InnerCard}" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource Brand}" VerticalAlignment="Top" Margin="0,5,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="任务已启动" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                            <TextBlock Margin="0,3,0,0" Text="{Binding SelectedTask.LastResult, Converter={StaticResource ChineseDisplay}}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource Brand}" VerticalAlignment="Top" Margin="0,5,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="配置已加载" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                            <TextBlock Margin="0,3,0,0" Text="路径与工作目录已读取" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource Brand}" VerticalAlignment="Top" Margin="0,5,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="等待进程结束" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                                            <TextBlock Margin="0,3,0,0" Text="{Binding SelectedTask.LastResult.Error, TargetNullValue=当前没有错误}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <Border x:Name="EmptyDetailState" Grid.ColumnSpan="3" Grid.RowSpan="2" Background="#F9FAFC" CornerRadius="10" IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedTask}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="选择一个任务" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                                <TextBlock Margin="0,6,0,0" Text="查看配置、运行记录和当前状态" Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="20,0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource Success}" />
                    <TextBlock Margin="8,0,0,0" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondary}" />
                    <TextBlock Margin="6,0,0,0" Text=" · " Foreground="#A1A9B5" />
                    <TextBlock Text="{Binding TaskSummary}" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource LinkButton}" Click="OpenLog_Click" Content="查看日志" />
            </Grid>
        </Border>
    </Grid>
</Window>
